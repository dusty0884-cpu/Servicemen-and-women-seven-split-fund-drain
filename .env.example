# ================================================================
# SockiiisBack — Environment Configuration
# ================================================================

# PayPal API (server-side, for Payouts API)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your_webhook_id

# Administrator PayPal Profile (public, rendered in UI)
# Set these to YOUR PayPal details at deployment time.
NEXT_PUBLIC_PAYPAL_ADMIN_ME_LINK=https://www.paypal.com/paypalme/YourUsername
NEXT_PUBLIC_PAYPAL_ADMIN_EMAIL=your-admin@email.com
NEXT_PUBLIC_ADMIN_DISPLAY_NAME=Your Name

# WMS Configuration
WMS_PROVIDER=mock
WMS_BASE_URL=
WMS_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
